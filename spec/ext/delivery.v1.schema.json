{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://akson.invalid/ext/delivery/v1/schema.json",
  "title": "Akson passive-delivery receipt v1 (design §9.2): durable-receipt metadata under the required delivery extension",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "message_id", "content_digest_sha256"],
  "properties": {
    "schema_version": { "const": 1 },
    "message_id": { "$ref": "#/$defs/a2aId" },
    "content_digest_sha256": {
      "$ref": "#/$defs/sha256hex",
      "description": "The RFC 9530 sha-256 Content-Digest of the exact stored request body."
    },
    "task_id": { "$ref": "#/$defs/a2aId" }
  },
  "$defs": {
    "sha256hex": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "a2aId": { "type": "string", "pattern": "^[\\x21-\\x7e]{1,128}$" }
  }
}
